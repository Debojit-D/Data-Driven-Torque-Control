<mujoco model="g1 scene nohands">
  <!-- Use the humanoid version *without* hands -->
  <include file="g1_without_hands.xml"/>

  <statistic center="0.3 0 .8" extent="1" meansize="0.08"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <global azimuth="180" elevation="-20"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker"
             rgb1=".2 .3 .4" rgb2=".1 0.15 0.2"
             width="512" height="512"
             mark="cross" markrgb=".8 .8 .8"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true"/>
    <texture type="2d" name="wood" file="assets/wood.png"/>
    <material name="wood" texture="wood"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" directional="true"/>

    <!-- Table -->
    <geom name="table" type="box" size=".5 .5 .3" mass="1"
          material="wood" pos="0.6 0 .3"/>

    <!-- Mocap targets unchanged -->
    <body name="com_target" pos="0.5 0 .5" mocap="true">
      <geom type="sphere" size=".06" contype="0" conaffinity="0" rgba=".6 .3 .3 .2"/>
      <site type="sphere" size="0.01" rgba="0 0 1 1" group="1"/>
    </body>

    <body name="left_palm_target" pos="0.5 0 .5" quat="0 1 0 0" mocap="true">
      <geom type="box" size=".04 .04 .04" contype="0" conaffinity="0" rgba=".6 .3 .3 .2"/>
      <site type="sphere" size="0.01" rgba="0 0 1 1" group="1"/>
    </body>

    <body name="right_palm_target" pos="0.5 0 .5" quat="0 1 0 0" mocap="true">
      <geom type="box" size=".04 .04 .04" contype="0" conaffinity="0" rgba=".6 .3 .3 .2"/>
      <site type="sphere" size="0.01" rgba="0 0 1 1" group="1"/>
    </body>

    <body name="left_foot_target" pos="0.5 0 .5" quat="0 1 0 0" mocap="true">
      <geom type="box" size=".04 .04 .04" contype="0" conaffinity="0" rgba=".6 .3 .3 .2"/>
      <site type="sphere" size="0.01" rgba="0 0 1 1" group="1"/>
    </body>

    <body name="right_foot_target" pos="0.5 0 .5" quat="0 1 0 0" mocap="true">
      <geom type="box" size=".04 .04 .04" contype="0" conaffinity="0" rgba=".6 .3 .3 .2"/>
      <site type="sphere" size="0.01" rgba="0 0 1 1" group="1"/>
    </body>

    <!-- Movable Tray -->
    <body name="tray" pos="0.5 0 0.61">
      <freejoint name="tray_freejoint"/>
      <inertial pos="0 0 0" mass="0.8" diaginertia="0.0005 0.0005 0.0005"/>

      <geom name="tray_left_wall"  type="box"
            pos="0.09  0     0.015" size="0.01 0.10 0.015" rgba="0.7 0.7 0.7 1"/>
      <geom name="tray_right_wall" type="box"
            pos="-0.09 0     0.015" size="0.01 0.10 0.015" rgba="0.7 0.7 0.7 1"/>
      <geom name="tray_front_wall" type="box"
            pos="0     0.09  0.015" size="0.10 0.01 0.015" rgba="0.7 0.7 0.7 1"/>
      <geom name="tray_back_wall"  type="box"
            pos="0    -0.09  0.015" size="0.10 0.01 0.015" rgba="0.7 0.7 0.7 1"/>

      <site name="tray_center" pos="0 0 0.02" size="0.01" rgba="0 1 0 0.4"/>
    </body>

    <!-- Cube 1: Red  -->
    <body name="cube_red" pos="0.45 0.3 0.62">
      <freejoint/>
      <inertial pos="0 0 0" mass="0.1" diaginertia="0.0002 0.0002 0.0002"/>
      <geom name="cube_red_geom"
            type="box"
            size="0.03 0.03 0.06"
            rgba="1 0 0 1"
            contype="1"
            conaffinity="1"
            friction="0.1 0.005 0.005"/>
    </body>

    <!-- Cube 2: Blue  -->
    <body name="cube_blue" pos="0.55 -0.3 0.62">
      <freejoint/>
      <inertial pos="0 0 0" mass="0.1" diaginertia="0.0002 0.0002 0.0002"/>
      <geom name="cube_blue_geom"
            type="box"
            size="0.03 0.03 0.03"
            rgba="0 0 1 1"
            contype="1"
            conaffinity="1"
            friction="1.0 0.005 0.0001"/>
    </body>

  </worldbody>

  <!-- Fix humanoid pelvis-included model to world -->
  <equality>
    <weld name="weld_pelvis" body1="pelvis" body2="world" solref="0.02 1"/>
  </equality>

  <!-- No hand-based distance sensors here, since humanoid has no hands -->
</mujoco>
